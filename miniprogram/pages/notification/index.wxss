.notification-header { margin: 8rpx 0 24rpx; }
.header-title { margin-bottom: 6rpx; }
.mark-read { margin: 0; border-radius: 999rpx; background: #fff2ee; color: #d85b3d; font-size: 24rpx; }
.mark-read::after { border: 0; }
.mark-read[disabled] { background: #f0f1f2; color: #a0a5ac; }
.notification { position: relative; display: flex; align-items: flex-start; }
.notification.unread { background: #fffaf8; }
.unread-dot { position: absolute; left: 10rpx; top: 18rpx; width: 14rpx; height: 14rpx; border-radius: 50%; background: #ff6b4a; }
.actor-avatar { width: 84rpx; height: 84rpx; border-radius: 50%; background: #eceff1; }
.notification-main { flex: 1; min-width: 0; margin-left: 18rpx; line-height: 1.5; }
.actor-name { font-weight: 650; }
.summary { margin-top: 8rpx; padding: 12rpx 16rpx; border-radius: 12rpx; background: #f5f6f7; color: #646a72; font-size: 24rpx; }
.time { margin-top: 8rpx; font-size: 22rpx; }
.type-icon { margin-left: 16rpx; color: #ff6b4a; font-size: 30rpx; }
