.me-page { padding-top: 18rpx; }
.profile-hero { position: relative; padding: 32rpx 28rpx 24rpx; overflow: hidden; border-radius: 38rpx; background: linear-gradient(135deg, #ff7a59 0%, #ff9a7c 54%, #ffc4ae 100%); box-shadow: 0 20rpx 48rpx rgba(255,111,77,.2); }
.profile-hero::after { content: ''; position: absolute; top: -130rpx; right: -100rpx; width: 310rpx; height: 310rpx; border-radius: 50%; background: rgba(255,255,255,.14); }
.profile-top { position: relative; z-index: 1; display: flex; align-items: flex-start; }
.profile-entry { display: flex; align-items: center; flex: 1; min-width: 0; }
.avatar-shell { width: 126rpx; height: 126rpx; flex: none; padding: 6rpx; border-radius: 50%; background: rgba(255,255,255,.85); box-shadow: 0 12rpx 24rpx rgba(121,62,43,.14); }
.profile-avatar { width: 114rpx; height: 114rpx; border-radius: 50%; background: #fff0e9; }
.profile-main { flex: 1; min-width: 0; margin-left: 20rpx; color: #fff; }
.profile-name { max-width: 270rpx; overflow: hidden; font-size: 36rpx; font-weight: 760; text-overflow: ellipsis; white-space: nowrap; }
.profile-bio { max-width: 360rpx; margin-top: 7rpx; overflow: hidden; color: rgba(255,255,255,.86); font-size: 23rpx; text-overflow: ellipsis; white-space: nowrap; }
.phone-bound { display: inline-flex; align-items: center; margin-top: 12rpx; padding: 6rpx 12rpx; border-radius: 999rpx; color: rgba(255,255,255,.92); background: rgba(106,56,39,.16); font-size: 20rpx; }
.verified-dot { display: inline-flex; align-items: center; justify-content: center; width: 24rpx; height: 24rpx; margin-right: 7rpx; border-radius: 50%; color: #3d8a64; background: #fff; font-size: 16rpx; font-weight: 750; }
.edit { position: relative; z-index: 2; flex: none; height: 56rpx; margin: 0; padding: 0 28rpx; border: 1rpx solid rgba(255,255,255,.5); border-radius: 999rpx; color: #fff; background: rgba(255,255,255,.14); font-size: 24rpx; line-height: 56rpx; }
.edit::after { border: 0; }
.stats { position: relative; z-index: 1; display: flex; align-items: center; margin-top: 30rpx; padding: 22rpx 12rpx 4rpx; border-top: 1rpx solid rgba(255,255,255,.22); text-align: center; }
.stat { flex: 1; color: #fff; }
.number { font-size: 32rpx; font-weight: 760; }
.stat-label { margin-top: 3rpx; color: rgba(255,255,255,.78); font-size: 21rpx; }
.divider { width: 1rpx; height: 40rpx; background: rgba(255,255,255,.22); }
.quick-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14rpx; margin: 20rpx 0 34rpx; }
.quick-item { position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 142rpx; border: 1rpx solid rgba(91,76,67,.05); border-radius: 26rpx; background: #fff; box-shadow: 0 10rpx 28rpx rgba(71,54,43,.06); }
.quick-icon { font-size: 36rpx; line-height: 1; }
.quick-label { margin-top: 13rpx; color: #5c544e; font-size: 23rpx; font-weight: 650; }
.badge { position: absolute; top: 14rpx; right: 18rpx; min-width: 32rpx; height: 32rpx; padding: 0 7rpx; border: 4rpx solid #fff; border-radius: 999rpx; color: #fff; background: #e8543f; font-size: 18rpx; line-height: 32rpx; text-align: center; }
.section-head { display: flex; align-items: flex-end; justify-content: space-between; margin: 8rpx 4rpx 16rpx; }
.section-name { margin-top: 4rpx; color: #3f3934; font-size: 32rpx; font-weight: 740; }
.menu-desc { margin-top: 4rpx; color: #9b948e; font-size: 21rpx; }
.admin-entry .menu-label { color: #d65d40; }
.admin-icon { color: #d65d40; background: #fff0e9; font-size: 21rpx; font-weight: 750; }
.post-section-head { margin-top: 34rpx; }
.post-count { color: #aaa29b; font-size: 22rpx; }
.compact-post { padding: 22rpx; }
.post-main-row { display: flex; }
.post-copy { flex: 1; min-width: 0; }
.compact-post .content { display: -webkit-box; overflow: hidden; color: #49423d; font-size: 27rpx; line-height: 1.55; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
.post-meta { margin-top: 13rpx; color: #a29b95; font-size: 21rpx; }
.post-cover { width: 132rpx; height: 104rpx; flex: none; margin-left: 20rpx; border-radius: 18rpx; background: #f0eeeb; }
.post-footer { display: flex; align-items: center; margin-top: 18rpx; padding-top: 14rpx; border-top: 1rpx solid #eeeae6; }
.post-data { display: flex; gap: 26rpx; color: #8e8781; font-size: 22rpx; }
.review-badge { margin-left: auto; padding: 6rpx 12rpx; border-radius: 999rpx; font-size: 20rpx; }
.review-badge.pending { color: #8b6b22; background: #fff7e8; }
.review-badge.rejected { color: #b44236; background: #fff0ee; }
.post-arrow { margin-left: auto; color: #a29b95; font-size: 22rpx; }
.my-empty { padding: 60rpx 20rpx; }
@media (prefers-color-scheme: dark) {
  .quick-item { border-color: rgba(255,255,255,.04); background: #1d1b19; box-shadow: none; }
  .quick-label, .section-name, .compact-post .content { color: #e4ded9; }
  .badge { border-color: #1d1b19; }
  .post-footer { border-color: #34302c; }
}
