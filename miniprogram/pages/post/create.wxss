.publish-page { padding-top: 18rpx; }
.publish-hero { display: flex; align-items: center; min-height: 230rpx; margin-bottom: 24rpx; padding: 30rpx; overflow: hidden; border-radius: 36rpx; background: linear-gradient(135deg, #fff0e8, #fff9f5 60%, #edf7f1); }
.publish-title { margin-top: 10rpx; color: #322925; font-size: 44rpx; font-weight: 780; line-height: 1.23; }
.publish-subtitle { width: 430rpx; margin-top: 14rpx; color: #8c7f77; font-size: 23rpx; line-height: 1.55; }
.publish-visual { position: relative; display: flex; align-items: center; justify-content: center; width: 150rpx; height: 150rpx; flex: none; margin-left: auto; border-radius: 48rpx; background: #fff; box-shadow: 0 14rpx 34rpx rgba(92,65,50,.1); font-size: 62rpx; transform: rotate(5deg); }
.visual-paw { position: absolute; right: -10rpx; bottom: -12rpx; display: flex; align-items: center; justify-content: center; width: 58rpx; height: 58rpx; border: 6rpx solid #fff7f2; border-radius: 50%; background: #ff8060; font-size: 28rpx; }
.card-label-row { display: flex; align-items: center; margin-bottom: 24rpx; }
.card-index { display: flex; align-items: center; justify-content: center; width: 54rpx; height: 54rpx; flex: none; margin-right: 16rpx; border-radius: 17rpx; color: #d75a3d; background: #fff0e9; font-size: 20rpx; font-weight: 750; }
.card-index.green { color: #408a65; background: #eaf7ef; }
.card-index.yellow { color: #977128; background: #fff5df; }
.compact-title { margin-bottom: 2rpx; font-size: 29rpx; }
.story-textarea { box-sizing: border-box; width: 100%; min-height: 270rpx; padding: 22rpx; border: 2rpx solid #eee8e3; border-radius: 22rpx; color: #413a35; background: #fbf9f7; font-size: 28rpx; line-height: 1.7; }
.counter { margin-top: 10rpx; color: #aaa29b; font-size: 21rpx; text-align: right; }
.counter.warning { color: #d75a3d; }
.select-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; }
.select-tile { display: flex; align-items: center; min-height: 100rpx; padding: 16rpx; border: 1rpx solid #eee8e3; border-radius: 22rpx; background: #fbf9f7; }
.select-icon { display: flex; align-items: center; justify-content: center; width: 52rpx; height: 52rpx; flex: none; border-radius: 17rpx; font-size: 25rpx; font-weight: 750; }
.pet-icon { background: #fff0e9; }
.topic-icon { color: #408a65; background: #eaf7ef; }
.select-copy { flex: 1; min-width: 0; margin-left: 13rpx; }
.select-label { color: #aaa29b; font-size: 19rpx; }
.select-value { max-width: 150rpx; margin-top: 3rpx; overflow: hidden; color: #4d4540; font-size: 24rpx; font-weight: 680; text-overflow: ellipsis; white-space: nowrap; }
.select-value.placeholder { color: #aaa29b; font-weight: 400; }
.select-arrow { color: #aaa29b; font-size: 25rpx; }
.media-head { align-items: flex-start; }
.media-heading { flex: 1; }
.image-count { color: #a29b95; font-size: 22rpx; }
.image-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; }
.image-wrap { position: relative; }
.selected-image, .add-image { width: 100%; height: 190rpx; border-radius: 20rpx; }
.selected-image { background: #f0eeeb; }
.add-image { display: flex; flex-direction: column; align-items: center; justify-content: center; box-sizing: border-box; border: 2rpx dashed #d9d2cc; color: #98918b; background: #faf8f6; }
.add-icon { font-size: 48rpx; line-height: 1; }
.add-text { margin-top: 10rpx; font-size: 20rpx; }
.remove { position: absolute; top: -8rpx; right: -8rpx; display: flex; align-items: center; justify-content: center; width: 42rpx; height: 42rpx; border: 4rpx solid #fff; border-radius: 50%; color: #fff; background: rgba(45,38,34,.78); font-size: 26rpx; }
.image-order { position: absolute; left: 9rpx; bottom: 9rpx; width: 34rpx; height: 34rpx; border-radius: 50%; color: #fff; background: rgba(45,38,34,.58); font-size: 18rpx; line-height: 34rpx; text-align: center; }
.notice-card { display: flex; align-items: flex-start; margin-bottom: 20rpx; padding: 20rpx; border-radius: 22rpx; color: #8c6a2c; background: #fff7e8; }
.notice-icon { display: flex; align-items: center; justify-content: center; width: 42rpx; height: 42rpx; flex: none; border-radius: 50%; color: #fff; background: #d5a54e; font-size: 22rpx; font-weight: 750; }
.notice-copy { margin-left: 14rpx; }
.notice-title { font-size: 24rpx; font-weight: 700; }
.notice-desc { margin-top: 5rpx; font-size: 21rpx; line-height: 1.55; }
.progress-panel { display: flex; align-items: center; justify-content: center; margin-bottom: 18rpx; color: #817a74; font-size: 22rpx; }
.progress-dot { width: 10rpx; height: 10rpx; margin-right: 10rpx; border-radius: 50%; background: #ff6f4d; box-shadow: 0 0 0 7rpx rgba(255,111,77,.11); }
.publish-action-card { margin-bottom: calc(28rpx + env(safe-area-inset-bottom)); padding: 28rpx; }
.publish-summary { margin-bottom: 20rpx; }
.summary-title { color: #4b433e; font-size: 28rpx; font-weight: 750; }
.summary-desc { margin-top: 6rpx; color: #a29b95; font-size: 21rpx; }
.publish-button { box-sizing: border-box; width: 100%; min-height: 92rpx; margin: 0; border-radius: 24rpx; color: #fff; background: linear-gradient(135deg, #ff6f4d, #ff8e6d); box-shadow: 0 12rpx 26rpx rgba(255,111,77,.22); font-size: 28rpx; font-weight: 700; line-height: 92rpx; }
.publish-button::after { border: 0; }
.empty-pet { padding: 56rpx 34rpx; text-align: center; }
.empty-pet-icon { font-size: 72rpx; }
.empty-pet-desc { margin: 10rpx auto 0; max-width: 500rpx; font-size: 24rpx; line-height: 1.6; }
.create-pet-button { width: 360rpx; margin: 28rpx auto 0; }
@media (prefers-color-scheme: dark) {
  .publish-hero { background: linear-gradient(135deg, #3a2721, #27211e 60%, #1f3028); }
  .publish-title { color: #f4f0ec; }
  .publish-visual { background: #24211e; box-shadow: none; }
  .story-textarea, .select-tile, .add-image { border-color: #38322e; color: #e7e1dc; background: #25221f; }
  .select-value { color: #e1dad4; }
  .remove { border-color: #1d1b19; }
  .publish-action-card { border-color: #38322e; background: #1d1b19; box-shadow: none; }
  .summary-title { color: #e7e1dc; }
}
