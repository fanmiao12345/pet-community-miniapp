.login-page {
  position: relative;
  box-sizing: border-box;
  min-height: 100vh;
  padding: calc(62rpx + env(safe-area-inset-top)) 34rpx calc(32rpx + env(safe-area-inset-bottom));
  overflow: hidden;
  background: linear-gradient(180deg, #fff4ed 0%, #faf5f0 42%, #f5f4f1 100%);
}

.decor { position: absolute; border-radius: 50%; opacity: 0.55; }
.decor-one { top: -100rpx; right: -130rpx; width: 360rpx; height: 360rpx; background: #ffd7c9; }
.decor-two { top: 360rpx; left: -170rpx; width: 300rpx; height: 300rpx; background: #e2f2e8; }

.brand-area { position: relative; z-index: 1; text-align: center; }
.brand-badge { display: inline-flex; padding: 9rpx 20rpx; border-radius: 999rpx; color: #a55742; background: rgba(255,255,255,.68); font-size: 21rpx; font-weight: 650; }
.pet-visual { display: flex; align-items: center; justify-content: center; height: 142rpx; margin-top: 20rpx; }
.paw-logo { display: flex; align-items: center; justify-content: center; width: 112rpx; height: 112rpx; border-radius: 36rpx; background: linear-gradient(135deg, #ff6f4d, #ff9b79); box-shadow: 0 20rpx 40rpx rgba(255,111,77,.24); font-size: 60rpx; transform: rotate(-5deg); }
.pet-bubble { display: flex; align-items: center; justify-content: center; width: 72rpx; height: 72rpx; border: 6rpx solid rgba(255,255,255,.9); border-radius: 50%; background: #fff; box-shadow: 0 12rpx 28rpx rgba(67,51,43,.1); font-size: 42rpx; }
.bubble-cat { margin-right: -14rpx; margin-top: 50rpx; transform: rotate(-8deg); }
.bubble-dog { margin-left: -14rpx; margin-top: -34rpx; transform: rotate(8deg); }
.brand-name { margin-top: 4rpx; color: #ff6f4d; font-size: 26rpx; font-weight: 750; letter-spacing: 5rpx; }
.brand-title { margin-top: 12rpx; color: #29231f; font-size: 48rpx; font-weight: 780; line-height: 1.25; letter-spacing: -2rpx; }
.brand-subtitle { width: 590rpx; max-width: 100%; margin: 18rpx auto 0; color: #817871; font-size: 25rpx; line-height: 1.65; }

.login-card { position: relative; z-index: 1; margin-top: 38rpx; padding: 34rpx 30rpx 30rpx; border: 1rpx solid rgba(91,76,67,.06); border-radius: 34rpx; background: rgba(255,255,255,.96); box-shadow: 0 24rpx 70rpx rgba(78,56,43,.11); }
.card-header { display: flex; align-items: flex-start; justify-content: space-between; }
.login-title { color: #2a2522; font-size: 34rpx; font-weight: 750; }
.login-desc { margin-top: 8rpx; color: #938b85; font-size: 23rpx; }
.secure-mark { padding: 8rpx 16rpx; border-radius: 999rpx; color: #408b66; background: #eaf7ef; font-size: 21rpx; font-weight: 700; }

.benefits { margin-top: 28rpx; padding: 4rpx 20rpx; border-radius: 24rpx; background: #faf7f4; }
.benefit { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #eee8e3; }
.benefit:last-child { border-bottom: 0; }
.benefit-icon { display: flex; align-items: center; justify-content: center; width: 54rpx; height: 54rpx; margin-right: 18rpx; border-radius: 17rpx; font-size: 22rpx; font-weight: 750; }
.privacy-icon { color: #a15a43; background: #fff0e9; }
.shield-icon { color: #3d8a64; background: #eaf7ef; }
.quick-icon { color: #8a6a2f; background: #fff5df; }
.benefit-title { color: #514a45; font-size: 25rpx; font-weight: 700; }
.benefit-desc { margin-top: 4rpx; color: #97908a; font-size: 22rpx; }

.agreement { display: flex; align-items: center; margin: 26rpx 2rpx 22rpx; padding: 18rpx 20rpx; border: 1rpx solid #eee8e3; border-radius: 20rpx; background: #fff; }
.checkbox { display: flex; align-items: center; justify-content: center; width: 36rpx; height: 36rpx; flex: 0 0 36rpx; margin-right: 14rpx; border: 2rpx solid #c9c2bc; border-radius: 11rpx; color: #fff; font-size: 23rpx; }
.checkbox.checked { border-color: #ff6f4d; background: #ff6f4d; }
.agreement-text { color: #77706a; font-size: 23rpx; line-height: 1.5; }
.link { color: #eb6242; font-weight: 650; }

.phone-button { display: flex; align-items: center; justify-content: center; min-height: 92rpx; border-radius: 999rpx; color: #fff !important; background: linear-gradient(135deg, #ff6f4d, #ff8e6d) !important; box-shadow: 0 14rpx 30rpx rgba(255,111,77,.25); font-size: 29rpx; font-weight: 720; }
.phone-button::after { border: 0; }
.phone-button[disabled] { color: #aaa39d !important; background: #e9e6e3 !important; box-shadow: none; }
.button-arrow { margin-left: 14rpx; font-size: 34rpx; line-height: 1; }
.status-row { display: flex; align-items: center; justify-content: center; margin-top: 20rpx; }
.status-dot { width: 10rpx; height: 10rpx; margin-right: 10rpx; border-radius: 50%; background: #b8b1ab; }
.status-dot.active { background: #ff6f4d; box-shadow: 0 0 0 8rpx rgba(255,111,77,.12); }
.status { color: #918a84; font-size: 22rpx; text-align: center; }
.mock-tip { margin-top: 12rpx; color: #a8784e; font-size: 21rpx; text-align: center; }
.bottom-note { position: relative; z-index: 1; margin-top: 24rpx; color: #aaa29b; font-size: 21rpx; text-align: center; }

@media (prefers-color-scheme: dark) {
  .login-page { background: linear-gradient(180deg, #2c211d 0%, #171513 48%, #12110f 100%); }
  .decor-one { background: #553229; }
  .decor-two { background: #203c2d; }
  .brand-badge { color: #eeb09e; background: rgba(255,255,255,.07); }
  .brand-title { color: #f4f0ec; }
  .brand-subtitle { color: #a59d96; }
  .login-card { border-color: rgba(255,255,255,.05); background: rgba(30,27,25,.98); box-shadow: none; }
  .login-title { color: #f4f0ec; }
  .benefits { background: #25211e; }
  .benefit { border-color: #37312d; }
  .benefit-title { color: #d8d1cb; }
  .agreement { border-color: #3a3430; background: #24211e; }
  .agreement-text { color: #aaa29b; }
  .pet-bubble { border-color: #2c2825; background: #24211e; }
}
