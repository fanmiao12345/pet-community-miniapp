.feed-page { padding-top: 18rpx; }
.feed-hero { position: relative; display: flex; min-height: 300rpx; margin-bottom: 26rpx; padding: 34rpx 30rpx; overflow: hidden; border-radius: 36rpx; background: linear-gradient(135deg, #fff0e7 0%, #fff8f2 56%, #edf7f1 100%); box-shadow: 0 18rpx 46rpx rgba(86,62,48,.08); }
.feed-hero::after { content: ''; position: absolute; right: -70rpx; bottom: -100rpx; width: 290rpx; height: 290rpx; border-radius: 50%; background: rgba(255,255,255,.55); }
.hero-copy { position: relative; z-index: 1; flex: 1; }
.hero-title { margin-top: 12rpx; color: #302722; font-size: 48rpx; font-weight: 780; line-height: 1.2; letter-spacing: -2rpx; }
.hero-subtitle { margin-top: 16rpx; color: #806f65; font-size: 24rpx; }
.hero-tags { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 24rpx; }
.hero-tags text { padding: 7rpx 13rpx; border-radius: 999rpx; color: #9c614f; background: rgba(255,255,255,.68); font-size: 20rpx; }
.hero-visual { position: relative; z-index: 2; align-self: center; width: 176rpx; height: 176rpx; margin-left: 14rpx; border: 8rpx solid rgba(255,255,255,.78); border-radius: 54rpx; background: linear-gradient(145deg, #ff8060, #ffab8f); box-shadow: 0 18rpx 38rpx rgba(255,111,77,.25); transform: rotate(5deg); }
.hero-pet { display: flex; align-items: center; justify-content: center; height: 118rpx; color: #fff; font-size: 72rpx; transform: rotate(-5deg); }
.hero-plus { position: absolute; top: -12rpx; right: -12rpx; display: flex; align-items: center; justify-content: center; width: 48rpx; height: 48rpx; border: 6rpx solid #fff6f0; border-radius: 50%; color: #fff; background: #4f9f78; font-size: 30rpx; line-height: 1; }
.hero-cta { height: 50rpx; color: #9b4c36; border-radius: 0 0 44rpx 44rpx; background: rgba(255,255,255,.82); font-size: 22rpx; font-weight: 700; line-height: 50rpx; text-align: center; transform: rotate(-5deg); }
.feed-toolbar { display: flex; align-items: center; justify-content: space-between; margin: 0 2rpx 20rpx; }
.feed-tabs { display: flex; padding: 6rpx; border-radius: 999rpx; background: #eae7e3; }
.feed-tab { min-width: 96rpx; padding: 10rpx 22rpx; border-radius: 999rpx; color: #817a74; font-size: 25rpx; text-align: center; }
.feed-tab.active { color: #fff; background: #ff6f4d; box-shadow: 0 8rpx 18rpx rgba(255,111,77,.2); font-weight: 700; }
.toolbar-hint { color: #a29b95; font-size: 21rpx; }
.loading { padding: 30rpx 16rpx 44rpx; font-size: 22rpx; text-align: center; }
.loading-dot { display: inline-block; width: 10rpx; height: 10rpx; margin-right: 12rpx; border-radius: 50%; background: #ff6f4d; }
.skeleton-card { overflow: hidden; }
.skeleton { border-radius: 12rpx; background: linear-gradient(90deg, #ebe7e3 25%, #f7f4f1 37%, #ebe7e3 63%); background-size: 400% 100%; animation: shimmer 1.4s ease infinite; }
.skeleton-row { display: flex; align-items: center; margin-bottom: 24rpx; }
.skeleton.circle { width: 76rpx; height: 76rpx; border-radius: 50%; }
.skeleton-lines { flex: 1; margin-left: 16rpx; }
.skeleton.line { height: 24rpx; margin-top: 16rpx; }
.skeleton.line.short { width: 45%; margin-top: 0; }
.skeleton.line.tiny { width: 28%; height: 18rpx; }
.skeleton.line.medium { width: 72%; }
.skeleton.image { height: 300rpx; margin-top: 22rpx; }
.error-state, .empty-state { padding: 54rpx 32rpx; text-align: center; }
.state-emoji { font-size: 70rpx; line-height: 1; }
.state-title { margin-top: 20rpx; color: #4e4742; font-size: 30rpx; font-weight: 720; }
.state-desc { margin: 12rpx auto 0; max-width: 520rpx; color: #99918b; font-size: 24rpx; line-height: 1.65; }
.retry-button, .empty-action { width: 240rpx; margin-top: 26rpx; border-radius: 999rpx; color: #e45f40; background: #fff0e9; font-size: 25rpx; font-weight: 650; }
.retry-button::after, .empty-action::after { border: 0; }
@keyframes shimmer { 0% { background-position: 100% 0; } 100% { background-position: 0 0; } }
@media (prefers-color-scheme: dark) {
  .feed-hero { background: linear-gradient(135deg, #3a2721 0%, #29231f 55%, #1e3028 100%); box-shadow: none; }
  .hero-title { color: #f4f0ec; }
  .hero-subtitle { color: #b7aaa2; }
  .hero-tags text { color: #dfad9e; background: rgba(255,255,255,.06); }
  .feed-tabs { background: #2a2724; }
  .skeleton { background: linear-gradient(90deg, #282522 25%, #34302c 37%, #282522 63%); background-size: 400% 100%; }
  .state-title { color: #e7e1dc; }
}
