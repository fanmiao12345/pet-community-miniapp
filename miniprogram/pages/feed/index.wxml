<view class="container feed-page">
  <view class="feed-hero">
    <view class="hero-copy">
      <view class="eyebrow">今日宠友圈</view>
      <view class="hero-title">和毛孩子<br />好好生活</view>
      <view class="hero-subtitle">记录成长，分享真实养宠经验</view>
      <view class="hero-tags">
        <text>真实分享</text><text>宠友互助</text><text>成长记录</text>
      </view>
    </view>
    <view class="hero-visual" bindtap="goPublish" aria-label="去发布动态">
      <view class="hero-pet">🐾</view>
      <view class="hero-plus">＋</view>
      <view class="hero-cta">发布动态</view>
    </view>
  </view>

  <view class="feed-toolbar">
    <view class="feed-tabs" role="tablist" aria-label="信息流切换">
      <view class="feed-tab {{feedMode === 'all' ? 'active' : ''}}" data-mode="all" bindtap="switchFeed" role="tab" aria-selected="{{feedMode === 'all'}}">推荐</view>
      <view class="feed-tab {{feedMode === 'following' ? 'active' : ''}}" data-mode="following" bindtap="switchFeed" role="tab" aria-selected="{{feedMode === 'following'}}">关注</view>
    </view>
    <view class="toolbar-hint">{{feedMode === 'following' ? '只看关注的人' : '发现社区新鲜事'}}</view>
  </view>

  <view wx:if="{{loading && posts.length === 0}}" class="skeleton-list" aria-label="正在加载动态">
    <view wx:for="{{[1,2,3]}}" wx:key="*this" class="card skeleton-card">
      <view class="skeleton-row"><view class="skeleton circle"></view><view class="skeleton-lines"><view class="skeleton line short"></view><view class="skeleton line tiny"></view></view></view>
      <view class="skeleton line"></view><view class="skeleton line medium"></view><view class="skeleton image"></view>
    </view>
  </view>

  <view wx:if="{{errorMessage && posts.length === 0}}" class="error-state card">
    <view class="state-emoji">😿</view>
    <view class="state-title">暂时加载失败</view>
    <view class="state-desc">{{errorMessage}}</view>
    <button class="retry-button" bindtap="retry">重新加载</button>
  </view>

  <post-card wx:for="{{posts}}" wx:key="id" post="{{item}}" bind:open="openPost" bind:author="openAuthor" bind:like="likePost" bind:favorite="favoritePost" />

  <view wx:if="{{!loading && !errorMessage && posts.length === 0}}" class="empty-state card">
    <view class="state-emoji">{{feedMode === 'following' ? '👀' : '🐾'}}</view>
    <view class="state-title">{{feedMode === 'following' ? '关注流还是空的' : '还没有动态'}}</view>
    <view class="state-desc">{{feedMode === 'following' ? '去发现喜欢的宠友，或先分享自己的第一条动态。' : '记录毛孩子今天发生的小故事吧。'}}</view>
    <button class="empty-action" bindtap="goPublish">去发布</button>
  </view>

  <view wx:if="{{loading && posts.length > 0}}" class="loading muted"><text class="loading-dot"></text>正在加载更多</view>
  <view wx:if="{{!loading && posts.length > 0 && !hasMore}}" class="loading muted">— 已经看到全部动态 —</view>
</view>
