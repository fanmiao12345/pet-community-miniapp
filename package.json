{
  "name": "pet-community-miniapp",
  "version": "1.2.1",
  "private": true,
  "description": "微信原生小程序 + TypeScript + CloudBase 的宠物社区个人项目",
  "scripts": {
    "check": "node scripts/check-project.js",
    "typecheck": "tsc -p tsconfig.json",
